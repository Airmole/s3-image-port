# Redis Configuration for Profile Sync
# Required for the E2E encrypted profile sync feature
# Format: redis://[username][:password]@host:port[/db]

# Local Redis instance
REDIS_URL=redis://localhost:6379

# Or using Redis Cloud / hosted service
# REDIS_URL=redis://username:password@your-redis-host.com:6379

# Optional access password for the whole app.
# If empty or not set, no password verification is required.
# VITE_ACCESS_PASSWORD=your-access-password

# Optional S3 settings overrides.
# If provided, these values take precedence over UI/local settings.
# Leave unset to keep existing behavior.
# (string vars are trimmed; empty string is treated as unset)

# S3 API endpoint (must be a full URL).
# VITE_S3_ENDPOINT=https://s3.example.com

# Bucket name.
# VITE_S3_BUCKET=my-bucket

# Region (e.g. us-east-1, or auto for some S3-compatible providers).
# VITE_S3_REGION=us-east-1

# Credentials for bucket access.
# VITE_S3_ACCESS_KEY_ID=AKIA...
# VITE_S3_SECRET_ACCESS_KEY=...

# Force path-style API.
# Accepts: true/false, 1/0, yes/no, on/off (case-insensitive).
# Invalid values are ignored.
# VITE_S3_FORCE_PATH_STYLE=false

# Public URL prefix used to build image links.
# VITE_S3_PUBLIC_URL=https://cdn.example.com

# Prefix filter for listing objects.
# Only affects list scope (gallery/read), does NOT change upload object keys.
# Empty means no filter.
# Prefer values like "images/" (no leading slash, usually trailing slash).
# VITE_S3_INCLUDE_PATH=images/
